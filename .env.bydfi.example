# BYDFI API Credentials for Crypto Trading
# ================================================
#
# How to get BYDFI API credentials:
# 1. Create account at https://www.bydfi.com
# 2. Go to API Management: https://www.bydfi.com/en/user/api-management
# 3. Create new API key
# 4. Save API Key and Secret Key (you won't see them again!)
# 5. Configure IP restrictions (recommended)
# 6. Enable permissions: Read Permission, Spot Trading Permission
#
# IMPORTANT: BYDFI uses API Key + HMAC SHA256 signature authentication
# This is SIMILAR to Binance but with different signature format
# No passphrase, no token refresh, no callback server, no OAuth complexity
#
# API Documentation: https://developers.bydfi.com/en/public

# BYDFI API Credentials
# ======================
BYDFI_API_KEY=your_bydfi_api_key_here
BYDFI_API_SECRET=your_bydfi_api_secret_here

# Exchange Environment
# ====================
# Options: production, testnet
# - production: Use for live trading (https://www.bydfi.com)
# - testnet: Use for testing (if available)
BYDFI_ENVIRONMENT=production

# Trading Symbol
# ==============
# Trading symbol (BYDFI format uses dash separator)
# Examples: BTC-USDT, ETH-USDT, SOL-USDT
# Currently supports: BTC-USDT only
BYDFI_TRADING_SYMBOL=BTC-USDT

# App Configuration
# =================
APP_ENV=development
LOG_LEVEL=INFO

# Risk Management Configuration
# ==============================
# Daily reset time for risk limits (UTC time, HH:MM format)
# Default: 00:00 (midnight UTC)
DAILY_RESET_TIME_UTC=00:00

# Position closing time (UTC time, HH:MM format)
# Default: 21:00 (5pm ET) - close all positions at this time
POSITION_CLOSE_TIME_UTC=21:00

# Weekend trading (crypto markets are 24/7)
# Options: true, false
ALLOW_WEEKEND_TRADING=true

# Dollar Bar Threshold (USD notional value)
# ==========================================
# Threshold for aggregating dollar bars from trade data
# Default: 10000000 ($10M) - crypto-specific (vs $50M for futures)
# TODO: Validate with research task (Phase 0, Task 0.1)
CRYPTO_DOLLAR_BAR_THRESHOLD=10000000

# Position Size Multiplier
# ========================
# Multiplier for position sizing (crypto volatility adjustment)
# Default: 0.3 (30% of futures size due to higher crypto volatility)
# TODO: Validate with research task (Phase 0, Task 0.5)
CRYPTO_POSITION_SIZE_MULTIPLIER=0.3

# Volatility Filter Threshold
# ============================
# ATR percentile threshold for volatility filter (0-100)
# Default: 75 (75th percentile)
# TODO: Validate with research task (Phase 0, Task 0.2)
ATR_PERCENTILE_THRESHOLD=75

# Setup Instructions
# ===================
# 1. Copy this file to .env.bydfi:
#    cp .env.bydfi.example .env.bydfi
#
# 2. Fill in your BYDFI API credentials:
#    - Get API key from BYDFI API Management
#    - Paste in BYDFI_API_KEY
#    - Paste in BYDFI_API_SECRET
#
# 3. Choose environment:
#    - For development: BYDFI_ENVIRONMENT=production (BYDFI uses same domain)
#
# 4. Configure risk parameters:
#    - Adjust DAILY_RESET_TIME_UTC and POSITION_CLOSE_TIME_UTC
#    - Set ALLOW_WEEKEND_TRADING=true for 24/7 crypto markets
#
# 5. NEVER commit .env.bydfi to version control!
#    - .env.bydfi is already in .gitignore
#    - Only commit .env.bydfi.example (this file)
