# Binance API Credentials for Crypto Trading
# ================================================
#
# How to get Binance API credentials:
# 1. Create account at https://www.binance.com (production) or https://testnet.binance.vision (testnet)
# 2. Go to API Management section
# 3. Create new API key
# 4. Save API Key and Secret Key (you won't see the secret again!)
# 5. Configure IP restrictions (recommended)
# 6. Enable permissions: Spot & Margin Trading (read-only for paper trading)
#
# IMPORTANT: Binance uses API Key + HMAC SHA256 signature authentication
# This is SIMPLER than TradeStation's OAuth 2.0 + PKCE flow
# No token refresh, no callback server, no PKCE complexity
#
# API Documentation: https://binance-docs.github.io/apids/

# Binance API Credentials
# =======================
CRYPTO_EXCHANGE_API_KEY=your_binance_api_key_here
CRYPTO_EXCHANGE_API_SECRET=your_binance_api_secret_here

# Exchange Environment
# ====================
# Options: testnet, production
# - testnet: Use for development and testing (https://testnet.binance.vision)
# - production: Use for live trading (https://www.binance.com)
CRYPTO_EXCHANGE_ENVIRONMENT=testnet

# Trading Symbols
# ===============
# List of trading symbols (comma-separated)
# Examples: BTCUSDT, ETHUSDT, SOLUSDT
# Currently supports: BTCUSDT only
CRYPTO_TRADING_SYMBOLS=BTCUSDT

# App Configuration
# =================
APP_ENV=development
LOG_LEVEL=INFO

# Risk Management Configuration
# ==============================
# Daily reset time for risk limits (UTC time, HH:MM format)
# Default: 00:00 (midnight UTC)
DAILY_RESET_TIME_UTC=00:00

# Position closing time (UTC time, HH:MM format)
# Default: 21:00 (5pm ET) - close all positions at this time
POSITION_CLOSE_TIME_UTC=21:00

# Weekend trading (crypto markets are 24/7)
# Options: true, false
ALLOW_WEEKEND_TRADING=true

# Dollar Bar Threshold (USD notional value)
# ==========================================
# Threshold for aggregating dollar bars from trade data
# Default: 10000000 ($10M) - crypto-specific (vs $50M for futures)
# TODO: Validate with research task (Phase 0, Task 0.1)
CRYPTO_DOLLAR_BAR_THRESHOLD=10000000

# Position Size Multiplier
# ========================
# Multiplier for position sizing (crypto volatility adjustment)
# Default: 0.3 (30% of futures size due to higher crypto volatility)
# TODO: Validate with research task (Phase 0, Task 0.5)
CRYPTO_POSITION_SIZE_MULTIPLIER=0.3

# Volatility Filter Threshold
# ============================
# ATR percentile threshold for volatility filter (0-100)
# Default: 75 (75th percentile)
# TODO: Validate with research task (Phase 0, Task 0.2)
ATR_PERCENTILE_THRESHOLD=75

# Setup Instructions
# ===================
# 1. Copy this file to .env.crypto:
#    cp .env.crypto.example .env.crypto
#
# 2. Fill in your Binance API credentials:
#    - Get API key from Binance API Management
#    - Paste in CRYPTO_EXCHANGE_API_KEY
#    - Paste in CRYPTO_EXCHANGE_API_SECRET
#
# 3. Choose environment:
#    - For development: CRYPTO_EXCHANGE_ENVIRONMENT=testnet
#    - For production: CRYPTO_EXCHANGE_ENVIRONMENT=production
#
# 4. Configure risk parameters:
#    - Adjust DAILY_RESET_TIME_UTC and POSITION_CLOSE_TIME_UTC
#    - Set ALLOW_WEEKEND_TRADING=true for 24/7 crypto markets
#
# 5. NEVER commit .env.crypto to version control!
#    - .env.crypto is already in .gitignore
#    - Only commit .env.crypto.example (this file)
