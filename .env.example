# TradeStation API Credentials
# Get these from your TradeStation developer account
TRADESTATION_CLIENT_ID=your_client_id_here
TRADESTATION_CLIENT_SECRET=your_client_secret_here
TRADESTATION_REDIRECT_URI=http://localhost:8080/callback
TRADESTATION_REFRESH_TOKEN=your_refresh_token_here

# App Configuration
APP_ENV=development
LOG_LEVEL=INFO

# Database Configuration (for future stories)
# DATABASE_URL=postgresql://user:password@localhost:5432/silverbullet

# Notification Configuration (for future stories)
# PUSHOVER_USER_KEY=your_pushover_user_key
# PUSHOVER_API_TOKEN=your_pushover_api_token
