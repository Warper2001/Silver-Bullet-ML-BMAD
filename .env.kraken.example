# Kraken API credentials — copy to .env and fill in real values
# DO NOT commit .env to git (it is gitignored)

# ---------------------------------------------------------------------------
# Kraken Futures API (for PF_XBTUSD perp short leg)
# Create at: https://futures.kraken.com → Account → API Keys
# Required permissions: Order Management (Create, Edit, Cancel)
# ---------------------------------------------------------------------------
KRAKEN_FUTURES_API_KEY=your_futures_api_key_here
KRAKEN_FUTURES_API_SECRET=your_futures_base64_secret_here

# ---------------------------------------------------------------------------
# Kraken Spot API (for BTC/USD spot long leg)
# Create at: https://www.kraken.com → Security → API
# Required permissions:
#   - Orders and Trades: Create & Modify Order, Cancel Order
#   - Funds: Query Funds
# NOTE: These are SEPARATE keys from Futures — different sub-systems on Kraken
# ---------------------------------------------------------------------------
KRAKEN_SPOT_API_KEY=your_spot_api_key_here
KRAKEN_SPOT_API_SECRET=your_spot_base64_secret_here

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------
# Paper mode (no credentials needed):
#   .venv/bin/python btc_carry_executor.py
#
# Live mode (all four vars above required):
#   .venv/bin/python btc_carry_executor.py --live
#
# Status check (paper — no credentials):
#   .venv/bin/python btc_carry_executor.py --status
#
# Status check (live — fetches real balances):
#   .venv/bin/python btc_carry_executor.py --live --status
