# KuCoin API Credentials for Crypto Trading
# ================================================
#
# How to get KuCoin API credentials:
# 1. Create account at https://www.kucoin.com (production) or https://sandbox.kucoin.com (sandbox)
# 2. Go to API Management section
# 3. Create new API key
# 4. Save API Key, Secret Key, and Passphrase (you won't see them again!)
# 5. Configure IP restrictions (recommended)
# 6. Enable permissions: Spot Trading (read-only for paper trading)
# 7. IMPORTANT: You must create a passphrase during API key creation
#
# IMPORTANT: KuCoin uses API Key + HMAC SHA256 signature + Passphrase authentication
# This is SIMILAR to Binance but adds a passphrase for additional security
# No token refresh, no callback server, no OAuth complexity
#
# API Documentation: https://docs.kucoin.com/

# KuCoin API Credentials
# ======================
KUCOIN_API_KEY=your_kucoin_api_key_here
KUCOIN_API_SECRET=your_kucoin_api_secret_here
KUCOIN_API_PASSPHRASE=your_kucoin_api_passphrase_here

# Exchange Environment
# ====================
# Options: sandbox, production
# - sandbox: Use for development and testing (https://sandbox.kucoin.com)
# - production: Use for live trading (https://www.kucoin.com)
KUCOIN_ENVIRONMENT=production

# Trading Symbol
# ==============
# Trading symbol (KuCoin format uses dash separator)
# Examples: BTC-USDT, ETH-USDT, SOL-USDT
# Currently supports: BTC-USDT only
KUCOIN_TRADING_SYMBOL=BTC-USDT

# App Configuration
# =================
APP_ENV=development
LOG_LEVEL=INFO

# Risk Management Configuration
# ==============================
# Daily reset time for risk limits (UTC time, HH:MM format)
# Default: 00:00 (midnight UTC)
DAILY_RESET_TIME_UTC=00:00

# Position closing time (UTC time, HH:MM format)
# Default: 21:00 (5pm ET) - close all positions at this time
POSITION_CLOSE_TIME_UTC=21:00

# Weekend trading (crypto markets are 24/7)
# Options: true, false
ALLOW_WEEKEND_TRADING=true

# Dollar Bar Threshold (USD notional value)
# ==========================================
# Threshold for aggregating dollar bars from trade data
# Default: 10000000 ($10M) - crypto-specific (vs $50M for futures)
# TODO: Validate with research task (Phase 0, Task 0.1)
CRYPTO_DOLLAR_BAR_THRESHOLD=10000000

# Position Size Multiplier
# ========================
# Multiplier for position sizing (crypto volatility adjustment)
# Default: 0.3 (30% of futures size due to higher crypto volatility)
# TODO: Validate with research task (Phase 0, Task 0.5)
CRYPTO_POSITION_SIZE_MULTIPLIER=0.3

# Volatility Filter Threshold
# ============================
# ATR percentile threshold for volatility filter (0-100)
# Default: 75 (75th percentile)
# TODO: Validate with research task (Phase 0, Task 0.2)
ATR_PERCENTILE_THRESHOLD=75

# Setup Instructions
# ===================
# 1. Copy this file to .env.kucoin:
#    cp .env.kucoin.example .env.kucoin
#
# 2. Fill in your KuCoin API credentials:
#    - Get API key from KuCoin API Management
#    - Paste in KUCOIN_API_KEY
#    - Paste in KUCOIN_API_SECRET
#    - Paste in KUCOIN_API_PASSPHRASE (created during API key setup)
#
# 3. Choose environment:
#    - For development: KUCOIN_ENVIRONMENT=sandbox
#    - For production: KUCOIN_ENVIRONMENT=production
#
# 4. Configure risk parameters:
#    - Adjust DAILY_RESET_TIME_UTC and POSITION_CLOSE_TIME_UTC
#    - Set ALLOW_WEEKEND_TRADING=true for 24/7 crypto markets
#
# 5. NEVER commit .env.kucoin to version control!
#    - .env.kucoin is already in .gitignore
#    - Only commit .env.kucoin.example (this file)
