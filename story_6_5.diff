+class MetaLabelingFilter:
+    """ML-based secondary filter that approves/rejects Tier 2 setups."""
+
+    FEATURE_COLS = [
+        'atr', 'gap_size', 'volume_ratio', 'et_hour', 'day_of_week', 'signal_direction',
